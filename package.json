    },
    "dependencies": {
        "bootstrap": "4.5.0"
    },
    "devDependencies": {
        "autoprefixer": "^10.4.2",
        "browser-sync": "^2.27.10",
        "chokidar": "3.4.0",
        "concurrently": "^6.4.0",
        "postcss": "8.2.13",
        "prettier": "2.0.5",
        "pug": "3.0.1",
        "sass": "1.26.8",
